# Build outputs
dist/

# Dependencies
node_modules/

# Generated asset trees (populated by `npm run prebuild` via scripts/copy-renders.ts)
# Source of truth lives in /renders/ and /construction/ at repo root.
public/renders/
public/construction/

# Brand-conflict imagery — filtered at copy-renders boundary, also excluded from VCS
construction/_social-covers/

# macOS
.DS_Store

# Editor / tooling
.vite/
.vscode/
.idea/

# Playwright cache
.playwright-mcp/

# Phase 6: build-time PNG artifacts generated by scripts/build-og-image.mjs from
# brand-assets/og/og.svg (OG image) and brand-assets/favicon/favicon-32.svg (icons).
# SVGs are source-of-truth; PNGs are reproducible from `npm run build` (idempotent
# mtime check in build-og-image.mjs). Excluding from git keeps repo clean.
public/og-image.png
public/apple-touch-icon.png
public/favicon-32.png

# QA/audit screenshots dropped in repo root by Playwright/manual sessions
/*.png

# Local audit artifacts and Lighthouse runs
audit/
.lighthouseci/

# Tooling/agent state — local-only
.agents/
.claude/
thoughts/
skills-lock.json
.gitignore.local

# Source brandbook binaries — too large for VCS, kept in cloud storage
*.ai
*.pdf

# Empty placeholder dir from prototype migration
вигода-—-системний-девелопмент/
